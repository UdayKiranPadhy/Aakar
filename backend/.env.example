# Copy to `.env` and fill in. `.env` is gitignored; this example is committed.
# backend/.env is loaded at startup by the composition root (aakar_api/di.py).

# HuggingFace token — required for gated models (Llama, Gemma, etc.).
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: override the backend CORS allowed origins (comma-separated).
# CORS_ORIGINS=http://localhost:5173

# Durable, shared Spec cache (Redis / serverless Redis such as Upstash).
# Leave unset for local dev — the backend then uses the local disk cache only.
# Accepts redis:// or rediss:// (TLS). Keep the real secret in .env, never in git.
REDIS_URL=

# Optional: Spec entry TTL in seconds. Defaults to 60 days. Specs are ~immutable
# for a given (model, config); the TTL just bounds the dataset on a capped plan.
# REDIS_SPEC_TTL_SECONDS=5184000
