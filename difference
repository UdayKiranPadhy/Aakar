@@ -0,0 +1,508 @@
+.view {
+  display: flex;
+  flex-direction: column;
+  gap: var(--space-8);
+  width: 100%;
+  max-width: 1280px;
+  margin: 0 auto;
+  padding: var(--space-8) var(--space-10) var(--space-16);
+}
+@media (max-width: 880px) {
+  .view {
+    gap: var(--space-6);
+    padding: var(--space-6) var(--space-5) var(--space-12);
+  }
+}
+
+/* ── Decade rail ───────────────────────────────────────────────────────── */
+.decadeRail {
+  position: relative;
+  display: grid;
+  grid-template-columns: repeat(8, 1fr);
+  gap: var(--space-2);
+  padding: var(--space-5) var(--space-4);
+  border: 1px solid var(--color-hairline);
+  border-radius: var(--radius-block);
+  background: var(--color-bg);
+  box-shadow: var(--shadow-block);
+  overflow-x: auto;
+}
+.decadeRail::before {
+  content: "";
+  position: absolute;
+  left: 9%;
+  right: 9%;
+  top: 41px;
+  height: 2px;
+  background: var(--color-hairline);
+  z-index: 0;
+}
+.decade {
+  position: relative;
+  z-index: 1;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 4px;
+  min-width: 84px;
+  padding: var(--space-2) 4px;
+  border-radius: var(--radius-md);
+  text-align: center;
+  transition: background var(--duration-fast) var(--ease-out);
+}
+.decade:hover {
+  background: var(--color-canvas);
+}
+.decadeDot {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 40px;
+  height: 40px;
+  border-radius: var(--radius-pill);
+  background: var(--tone-soft);
+  color: var(--tone);
+  font-family: var(--font-sans);
+  font-size: 12px;
+  font-weight: var(--weight-bold);
+  box-shadow: 0 0 0 4px var(--color-bg);
+}
+.decadeActive .decadeDot {
+  box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 6px var(--tone);
+}
+.decadeLabel {
+  font-family: var(--font-sans);
+  font-size: 13px;
+  font-weight: var(--weight-bold);
+  color: var(--color-ink);
+}
+.decadeTitle {
+  font-family: var(--font-sans);
+  font-size: 11.5px;
+  font-weight: var(--weight-medium);
+  line-height: 1.2;
+  color: var(--color-ink-muted);
+}
+.decadeSub {
+  font-family: var(--font-sans);
+  font-size: 11px;
+  color: var(--color-ink-subtle);
+}
+
+/* ── Timeline split (master list + detail) ─────────────────────────────── */
+.split {
+  display: grid;
+  grid-template-columns: minmax(300px, 0.8fr) 1.2fr;
+  gap: var(--space-6);
+  align-items: start;
+}
+@media (max-width: 940px) {
+  .split {
+    grid-template-columns: 1fr;
+  }
+}
+
+.master {
+  display: flex;
+  flex-direction: column;
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+.masterItem {
+  display: grid;
+  grid-template-columns: 28px 1fr auto;
+  align-items: stretch;
+  gap: var(--space-3);
+  width: 100%;
+  padding: var(--space-3) var(--space-3) var(--space-3) 0;
+  border-radius: var(--radius-md);
+  text-align: start;
+  transition: background var(--duration-fast) var(--ease-out);
+}
+.masterItem:hover {
+  background: var(--color-canvas);
+}
+.masterItemActive {
+  background: var(--color-accent-subtle);
+}
+
+/* Vertical connector with a coloured node. */
+.rail {
+  position: relative;
+  display: flex;
+  justify-content: center;
+}
+.rail::before {
+  content: "";
+  position: absolute;
+  top: 0;
+  bottom: 0;
+  width: 2px;
+  background: var(--color-hairline);
+}
