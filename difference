+export type GlossaryTerm = Readonly<{
+  term: string;
+  abbr?: string;
+  definition: string;
+  related: ReadonlyArray<string>;
+}>;
+
+/* ── Fun facts (Overview) ──────────────────────────────────────────────── */
+
+export type FunFact = Readonly<{
+  id: string;
+  text: string;
+  accent: AccentTone;
+}>;
